 montagem do espaço, contratação da equipe e inauguração com suporte total."}],XD=[{titulo:"Prêmio 4 Estrelas",org:"Pequenas Empresas & Grandes Negócios",anos:"2024"},{titulo:"Excelência em Franquias",org:"ANEC",anos:"2020, 2022, 2024"},{titulo:"Latin American Franchise",org:"Associação Latino-Americana",anos:"2022, 2023, 2024, 2025"}],ZD=[{pergunta:"Qual a rentabilidade do negócio?",resposta:"Graças ao nosso mix exclusivo de produtos e serviços de alta qualidade, nossos franqueados desfrutam de uma margem de lucro média de 20% a 40%. Isso garante uma operação sólida e rentável, com retorno consistente sobre o investimento."},{pergunta:"Que tipo de suporte a franqueadora oferece?",resposta:"Você não estará sozinho! Contamos com uma equipe especializada de consultores à disposição para ajudar em todos os aspectos da gestão, desde treinamentos até contratações e otimizações operacionais. Estamos aqui para apoiar o sucesso do seu negócio em cada etapa."},{pergunta:"Preciso ter o ponto comercial para começar?",resposta:"Não se preocupe! Nossa equipe de consultores junto de um sistema de Geomarketing vai te auxiliar na busca pelo ponto ideal, além de cuidar de todo o projeto arquitetônico do novo espaço, garantindo que ele esteja alinhado aos padrões VIP."},{pergunta:"Preciso ser ou ter um barbeiro para começar?",resposta:"Não é necessário! Nossa equipe de especialistas cuida da contratação de barbearia para você, garantindo que seu time esteja pronto para iniciar as operações com excelência, sem que você precise ter experiência prévia no setor."},{pergunta:"Quem faz o Marketing da minha unidade?",resposta:"Nós cuidamos de tudo para você! A franqueadora oferece suporte completo para o marketing da sua unidade, criando materiais profissionais, como fotos, vídeos, banners e muito mais. Você terá tudo o que precisa para fortalecer sua presença online e offline."},{pergunta:"Quais são os diferenciais da Barbearia VIP?",resposta:"Nossa rede se destaca pela credibilidade no mercado de estética masculina, graças à qualidade superior dos produtos e serviços. Além disso, oferecemos uma experiência única, com espaços exclusivos voltados para o lazer e relaxamento dos clientes enquanto cuidam do visual."}],e_=[{range:"R$ 250k – R$ 300k",tipo:"Franquia Padrão"},{range:"Acima de R$ 350k",tipo:"Franquia Master"}];function jx({end:t,prefix:e="",suffix:n="",label:s,duration:a=2e3,decimals:i=0,separator:l="."}){const{ref:d,formatted:f}=KD({end:t,prefix:e,suffix:n,duration:a,decimals:i,separator:l});return c.jsxs("div",{"data-loc":"client/src/components/FranquiaSection.tsx:145",ref:d,className:"p-5 rounded-sm text-center",style:{backgroundColor:"rgba(255,255,255,0.04)",backdropFilter:"blur(8px)"},children:[c.jsx("div",{"data-loc":"client/src/components/FranquiaSection.tsx:150",className:"font-headline text-vip-green",style:{fontSize:"clamp(1.4rem, 3.5vw, 2rem)",lineHeight:1,fontWeight:800},children:f}),c.jsx("div",{"data-loc":"client/src/components/FranquiaSection.tsx:156",className:"label-vip mt-2 text-[#889487]",style:{fontSize:"0.65rem"},children:s})]})}function M4(){const[t,e]=N.useState(null),n=N.useRef(null),[s,a]=N.useState(!1),[i,l]=N.useState(!1);N.useEffect(()=>{const f=n.current;if(!f)return;const m=()=>{f.play().catch(()=>{})};return f.addEventListener("canplay",m,{once:!0}),()=>f.removeEventListener("canplay",m)},[]);const d=s&&!i;return c.jsxs("section",{"data-loc":"client/src/components/FranquiaSection.tsx:183",id:"franquia",style:{backgroundColor:"#131313"},children:[c.jsxs("div",{"data-loc":"client/src/components/FranquiaSection.tsx:186",className:"relative overflow-hidden",style:{minHeight:"100svh",backgroundColor:"#131313"},children:[c.jsxs("div",{"data-loc":"client/src/components/FranquiaSection.tsx:191",className:"absolute inset-0 z-0",style:{WebkitTransform:"translateZ(0)",transform:"translateZ(0)"},children:[c.jsx("img",{"data-loc":"client/src/components/FranquiaSection.tsx:196",src:YD,alt:"Interior da Barbearia VIP — ambiente