        @keyframes chatbotFadeIn {
          from { opacity: 0; transform: translateY(12px) scale(0.96); }
          to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes chatbotMsg {
          from { opacity: 0; transform: translateY(4px); }
          to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes chatbotPing {
          0%, 100% { transform: scale(1); opacity: 0.7; }
          50% { transform: scale(1.5); opacity: 0; }
        }
        .chatbot-window {
          animation: chatbotFadeIn 0.25s cubic-bezier(0.34,1.56,0.64,1) forwards;
        }
        .chatbot-msg-anim {
          animation: chatbotMsg 0.2s ease forwards;
        }
        .chatbot-scroll::-webkit-scrollbar {
          width: 3px;
        }
        .chatbot-scroll::-webkit-scrollbar-track {
          background: transparent;
        }
        .chatbot-scroll::-webkit-scrollbar-thumb {
          background: rgba(112,220,143,0.25);
          border-radius: 99px;
        }
        .chatbot-cta {
          display: flex;
          align-items: center;
          gap: 8px;
          margin-top: 8px;
          padding: 10px 14px;
          background: #25D366;
          color: #fff !important;
          font-weight: 700;
          font-size: 13px;
          line-height: 1.3;
          border-radius: 10px;
          text-decoration: none !important;
          transition: background 0.15s, transform 0.12s;
          width: 100%;
          box-sizing: border-box;
          word-break: break-word;
        }
        .chatbot-cta:hover {
          background: #1da851;
          transform: scale(1.02);
        }
        .chatbot-inline-link {
          color: #70dc8f;
          text-decoration: underline;
          font-size: 12px;
          margin-top: 6px;
          display: inline-block;
        }
        .chatbot-inline-link:hover { color: #5ac97a; }
        .chatbot-option-btn {
          display: block;
          width: 100%;
          text-align: left;
          padding: 9px 12px;
          border-radius: 10px;
          font-size: 13px;
          font-weight: 600;
          line-height: 1.4;
          cursor: pointer;
          transition: background 0.15s, transform 0.1s;
          word-break: break-word;
          white-space: normal;
        }
        .chatbot-option-btn:hover { transform: scale(1.01); }
        .chatbot-option-green {
          background: rgba(112,220,143,0.12);
          color: #70dc8f;
          border: 1px solid rgba(112,220,143,0.25);
        }
        .chatbot-option-green:hover { background: rgba(112,220,143,0.2); }
